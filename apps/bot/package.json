{
  "name": "@system-hunter/bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "npm run build -w @system-hunter/shared && tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
